# OpenAI API Key
OPENAI_API_KEY=
DATABASE_URL="postgresql://user:password@localhost:5432/finance_db?schema=public"

# Docker specific (used by docker-compose.yml)
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=finance_db

JWT_SECRET=
EXCHANGERATE_API_KEY=
NODE_ENV="development"
DEEPSEEK_API_KEY=

# Encryption key for password recovery (32 characters for AES-256)
ENCRYPTION_KEY=

# SMTP Configuration for sending emails
# Note: For Gmail, use an App Password (https://myaccount.google.com/apppasswords)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-16-char-app-password
SMTP_FROM="Finance App <your-email@gmail.com>"
